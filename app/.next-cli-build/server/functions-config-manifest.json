{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/static|_next\\/image|favicon\\.ico).*))(\\.json|\\.rsc|\\.segments\\/.+\\.segment\\.rsc)?[\\/#\\?]?$",
          "originalSource": "/((?!_next/static|_next/image|favicon\\.ico).*)"
        }
      ]
    },
    "/api/mcp/[plugin]/message": {},
    "/api/mcp/[plugin]/sse": {},
    "/api/v1/audio/transcriptions": {
      "maxDuration": 300
    }
  }
}