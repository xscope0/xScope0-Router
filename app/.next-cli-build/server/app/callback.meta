{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/callback/layout,_N_T_/callback/page,_N_T_/callback"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/callback/__PAGE__",
    "/callback",
    "/_index",
    "/_head"
  ]
}